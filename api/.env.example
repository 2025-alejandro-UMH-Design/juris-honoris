# ─────────────────────────────────────────────
#  Base de datos PRIMARIA
#  Usa DATABASE_PRIMARY_URL (connection string completa)
#  O las variables individuales DB_PRIMARY_*
# ─────────────────────────────────────────────
DATABASE_PRIMARY_URL=postgresql://usuario:password@host:5432/juris_honoris
# DB_PRIMARY_HOST=localhost
# DB_PRIMARY_PORT=5432
# DB_PRIMARY_NAME=juris_honoris
# DB_PRIMARY_USER=postgres
# DB_PRIMARY_PASSWORD=tu_password

# ─────────────────────────────────────────────
#  Base de datos RESPALDO (opcional)
#  Si no se configura, el switch a "backup" dará error
# ─────────────────────────────────────────────
DATABASE_BACKUP_URL=postgresql://usuario:password@host-respaldo:5432/juris_honoris

# ─────────────────────────────────────────────
#  Cual DB usar al arrancar (primary | backup)
# ─────────────────────────────────────────────
DATABASE_ACTIVE=primary

# ─────────────────────────────────────────────
#  Auth
# ─────────────────────────────────────────────
JWT_SECRET=cambia_este_secreto_en_produccion_usa_min_32_chars
JWT_EXPIRES_IN=7d

# ─────────────────────────────────────────────
#  Servidor
# ─────────────────────────────────────────────
PORT=3000

# ─────────────────────────────────────────────
#  Cloudinary (almacenamiento de archivos)
#  Obtener en: cloudinary.com → Dashboard → API Keys
# ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret
